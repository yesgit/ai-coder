{
  "name": "careful-coder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "谨慎程序员",
    "email": "aicoder@example.com"
  },
  "description": "谨慎程序员桌面编码 Agent。",
  "main": "dist/main/main.js",
  "desktopName": "careful-coder.desktop",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:icon": "node scripts/make-icon.cjs",
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "test": "vitest run",
    "pack:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.aicoder.desktop",
    "productName": "谨慎程序员",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "workflows/*.yaml",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "workflows",
        "to": "workflows",
        "filter": [
          "*.yaml"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "syncDesktopName": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@napi-rs/canvas": "^1.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.0"
  }
}
